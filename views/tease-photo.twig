{% extends "tease.twig" %}

{% block content %}
    <a href="{{ post.meta('link') }}" alt="Перейти в альбом {{ post.meta('link') }}">
        {% if post.thumbnail.src %}
            <div class="tease-thumbnail" style="background-image: url({{ post.thumbnail.src('large') }})" ></div>
        {% endif %}
        <div class="tease-content">
            <h3>
                {{ post.title }}
            </h3>
            <div class="tease-details">
                {{ post.category }} • {{ post.date }}
            </div>
        </div>
    </a>

{% endblock %}